# Required — admin credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_strong_password

# Required — JWT signing secret (generate with: openssl rand -base64 64)
JWT_SECRET=change_me_jwt_secret_at_least_32_characters_long

# Required — database password
POSTGRES_PASSWORD=techradar_dev

# Optional — GitHub PAT improves rate limits (10 req/min unauth → 30 req/min auth)
# Create at: https://github.com/settings/tokens (no scopes needed for public repo search)
# GITHUB_PAT=ghp_your_github_personal_access_token

# Optional — Anthropic API key for LLM-enriched proposal generation.
# When absent the system runs in manual-classification mode: agents still discover
# and queue signals, but quadrant/ring/rationale must be set by the admin during review.
# ANTHROPIC_API_KEY=sk-ant-your_key_here

# Agent schedule (cron expression; default: daily at 03:00 UTC)
AGENTS_SCHEDULE_CRON=0 3 * * *

# Maximum proposals generated per agent run (excess are dropped and counted)
AGENTS_MAX_PROPOSALS_PER_RUN=50

# Days before a pending proposal is flagged as stale in the review queue
AGENTS_STALE_PROPOSAL_THRESHOLD_DAYS=7

# Anthropic model used for proposal classification (only used when ANTHROPIC_API_KEY is set)
AGENTS_ANTHROPIC_MODEL=claude-haiku-4-5-20251001
